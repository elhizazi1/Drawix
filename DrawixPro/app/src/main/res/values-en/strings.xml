    <string name="faq_title">FAQ &amp; User Guide</string>
    <string name="faq_q1">How do I use the interactive laser?</string>
    <string name="faq_a1">Select the laser tool from the panel; the glowing tail follows your finger and fades instantly to guide attention.</string>
    <string name="faq_q2">How do I protect sensitive data?</string>
    <string name="faq_a2">Use the "Censor" (checkerboard) tool to blur texts or faces before capturing.</string>
    <string name="faq_q3">Where are screenshots saved?</string>
    <string name="faq_a3">All captures are saved automatically in the app\'s "Gallery" tab.</string>
