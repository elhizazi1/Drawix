    <string name="permissions_title">Security &amp; Permissions</string>
    <string name="permissions_privacy_title">Privacy First</string>
    <string name="permissions_privacy_desc">We believe in absolute transparency. The app works entirely offline and does not collect, store, or send any personal data or screens to any external server.</string>
    <string name="permissions_manage_title">Manage Permissions</string>
    <string name="permissions_accessibility_title">Accessibility</string>
    <string name="permissions_accessibility_desc">To show drawing tools over all interfaces, including the status bar.</string>
    <string name="accessibility_auto_revoke_note">For your security, Android automatically revokes this permission if the app is inactive. This is a great routine to protect your phone, just re-enable it when needed!</string>
    <string name="permissions_overlay_title">Display Over Other Apps</string>
    <string name="permissions_overlay_desc">To keep the floating button visible and ready to use anywhere.</string>
    <string name="permissions_storage_title">Storage Access</string>
    <string name="permissions_storage_desc">To save screenshots and drawings in your gallery.</string>
    <string name="permissions_notifications_title">Smart Notifications</string>
    <string name="permissions_notifications_desc">To receive alerts upon successful saves or to remind you when the floating tool is active.</string>
    <string name="permissions_battery_title">Battery Optimization Exception</string>
    <string name="permissions_battery_desc">To prevent the system from unexpectedly killing the floating service in the background.</string>
    <string name="permissions_device_note_title">Important Note for Some Devices</string>
    <string name="permissions_device_note_desc">Despite granting permissions, some devices (like Xiaomi/Oppo) may block the floating button due to power saving. If so, Force Stop the app and reopen it to refresh permissions.</string>
    <string name="permission_request">Please enable \"Display over other apps\" first</string>
    <string name="accessibility_service_desc">This permission is required to silently and quickly capture the screen upon your request.</string>
