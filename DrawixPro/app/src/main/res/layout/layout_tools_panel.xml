<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:gravity="center_horizontal|bottom"
    android:orientation="vertical"
    android:padding="18dp">

    <!-- 1. حاوية الألوان المخصصة (تم نقلها للأعلى وتصميمها أفقياً) -->
    <LinearLayout
        android:id="@+id/custom_picker_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_glass_panel"
        android:elevation="12dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="16dp"
        android:visibility="gone">

        <FrameLayout
            android:id="@+id/color_wheel_frame"
            android:layout_width="140dp"
            android:layout_height="140dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:gravity="center"
            android:orientation="vertical">

            <View
                android:id="@+id/color_preview"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_modern_button"
                android:backgroundTint="#FFFFFF"
                android:elevation="4dp" />

            <Button
                android:id="@+id/btn_apply_custom_color"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_rect_button"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/btn_apply"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 2. حاوية الألوان السريعة (تم نقلها للأعلى فوق الأدوات مباشرة) -->
    <LinearLayout
        android:id="@+id/colors_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_glass_panel"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="8dp"
        android:visibility="gone">

        <View android:id="@+id/color_red" android:layout_width="28dp" android:layout_height="28dp" android:layout_margin="4dp" android:background="@drawable/bg_modern_button" android:backgroundTint="@color/status_error" />
        <View android:id="@+id/color_blue" android:layout_width="28dp" android:layout_height="28dp" android:layout_margin="4dp" android:background="@drawable/bg_modern_button" android:backgroundTint="@color/status_info" />
        <View android:id="@+id/color_green" android:layout_width="28dp" android:layout_height="28dp" android:layout_margin="4dp" android:background="@drawable/bg_modern_button" android:backgroundTint="@color/status_success" />
        <View android:id="@+id/color_yellow" android:layout_width="28dp" android:layout_height="28dp" android:layout_margin="4dp" android:background="@drawable/bg_modern_button" android:backgroundTint="@color/status_warning" />
        <View android:id="@+id/color_teal" android:layout_width="28dp" android:layout_height="28dp" android:layout_margin="4dp" android:background="@drawable/bg_modern_button" android:backgroundTint="@color/colorPrimary" />
        <View android:id="@+id/color_black" android:layout_width="28dp" android:layout_height="28dp" android:layout_margin="4dp" android:background="@drawable/bg_modern_button" android:backgroundTint="#FAFAFA" />
        
        <ImageView
            android:id="@+id/color_custom"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_tool_button"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_color_swatch"
            android:tint="#FFFFFF"
            app:tint="#FFFFFF" />
    </LinearLayout>

    <!-- 3. حاوية الأدوات الرئيسية -->
    <LinearLayout
        android:id="@+id/panel_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_panel"
        android:clipChildren="false"
        android:elevation="12dp"
        android:orientation="vertical"
        android:padding="6dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">
            
            <ImageView android:id="@+id/tool_brush" android:layout_width="42dp" android:layout_height="42dp" android:layout_margin="3dp" android:background="@drawable/bg_tool_button" android:padding="10dp" android:scaleType="fitCenter" android:src="@drawable/ic_brush_2" app:tint="#FFFFFF" />
            <ImageView android:id="@+id/tool_rect" android:layout_width="42dp" android:layout_height="42dp" android:layout_margin="3dp" android:background="@drawable/bg_tool_button" android:padding="10dp" android:scaleType="fitCenter" android:src="@drawable/ic_format_square" app:tint="#FFFFFF" />
            <ImageView android:id="@+id/tool_circle" android:layout_width="42dp" android:layout_height="42dp" android:layout_margin="3dp" android:background="@drawable/bg_tool_button" android:padding="10dp" android:scaleType="fitCenter" android:src="@drawable/ic_format_circle" app:tint="#FFFFFF" />
            <ImageView android:id="@+id/tool_arrow" android:layout_width="42dp" android:layout_height="42dp" android:layout_margin="3dp" android:background="@drawable/bg_tool_button" android:padding="10dp" android:scaleType="fitCenter" android:src="@drawable/ic_arrow" app:tint="#FFFFFF" />
            <ImageView android:id="@+id/tool_text" android:layout_width="42dp" android:layout_height="42dp" android:layout_margin="3dp" android:background="@drawable/bg_tool_button" android:padding="10dp" android:scaleType="fitCenter" android:src="@drawable/ic_text" app:tint="#FFFFFF" />
            <ImageView android:id="@+id/tool_censor" android:layout_width="42dp" android:layout_height="42dp" android:layout_margin="3dp" android:background="@drawable/bg_tool_button" android:padding="10dp" android:scaleType="fitCenter" android:src="@drawable/ic_blur" app:tint="#FFFFFF" />
            <ImageView android:id="@+id/tool_color_picker" android:layout_width="42dp" android:layout_height="42dp" android:layout_margin="3dp" android:background="@drawable/bg_tool_button" android:padding="10dp" android:scaleType="fitCenter" android:src="@drawable/ic_colorfilter" app:tint="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center"
            android:orientation="horizontal">
            
            <ImageView android:id="@+id/tool_move" android:layout_width="42dp" android:layout_height="42dp" android:layout_margin="3dp" android:background="@drawable/bg_tool_button" android:padding="10dp" android:scaleType="fitCenter" android:src="@drawable/ic_pointer" app:tint="#FFFFFF" />
            <ImageView android:id="@+id/tool_laser" android:layout_width="42dp" android:layout_height="42dp" android:layout_margin="3dp" android:background="@drawable/bg_tool_button" android:padding="10dp" android:scaleType="fitCenter" android:src="@drawable/ic_magicpen" app:tint="#FFFFFF" />
            <ImageView android:id="@+id/tool_laser_mode" android:layout_width="42dp" android:layout_height="42dp" android:layout_margin="3dp" android:background="@drawable/bg_tool_button" android:padding="10dp" android:scaleType="fitCenter" android:src="@drawable/ic_timer" app:tint="#FFFFFF" />
            <ImageView android:id="@+id/tool_eraser" android:layout_width="42dp" android:layout_height="42dp" android:layout_margin="3dp" android:background="@drawable/bg_tool_button" android:padding="10dp" android:scaleType="fitCenter" android:src="@drawable/ic_eraser" app:tint="#FFFFFF" />
            <ImageView android:id="@+id/tool_undo" android:layout_width="42dp" android:layout_height="42dp" android:layout_margin="3dp" android:background="@drawable/bg_tool_button" android:padding="10dp" android:scaleType="fitCenter" android:src="@drawable/ic_arrow_rotate_left" app:tint="#FFFFFF" />
            <ImageView android:id="@+id/tool_clear" android:layout_width="42dp" android:layout_height="42dp" android:layout_margin="3dp" android:background="@drawable/bg_tool_button" android:padding="10dp" android:scaleType="fitCenter" android:src="@drawable/ic_trash" app:tint="#FFFFFF" />
            <ImageView android:id="@+id/tool_screenshot" android:layout_width="42dp" android:layout_height="42dp" android:layout_margin="3dp" android:background="@drawable/bg_tool_button" android:padding="10dp" android:scaleType="fitCenter" android:src="@drawable/ic_camera" app:tint="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>

    <!-- 4. الحاوية الجديدة (أزرار الإعدادات والإغلاق) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/tool_settings"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_glass_panel"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_setting_2"
            app:tint="#FFFFFF" />

        <ImageView
            android:id="@+id/tool_close"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_glass_panel"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_close_square"
            app:tint="#FF4444" />
    </LinearLayout>

</LinearLayout>
